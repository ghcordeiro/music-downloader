SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_OAUTH_CLIENT_ID=your_oauth_client_id_here

# OAuth redirect (login da conta Spotify do usuário):
# RECOMENDADO (funciona para qualquer usuário, sem túnel/servidor):
#   1. No Spotify Dashboard, cadastre o redirect URI EXATO: http://127.0.0.1:8888/callback
#   2. Deixe SPOTIFY_OAUTH_REDIRECT_URI vazio e use a porta fixa 8888 abaixo.
#   O app sobe um servidor local na porta 8888 (loopback). Porta fixa casa de forma
#   determinística. Não use "localhost" (o Spotify rejeita) nem porta dinâmica
#   (o match de porta variável do Spotify é instável: "Not matching configuration").
SPOTIFY_OAUTH_REDIRECT_URI=
SPOTIFY_OAUTH_CALLBACK_PORT=8888

# LEGADO (opcional): redirect HTTPS fixo via túnel/servidor próprio, ex.:
#   SPOTIFY_OAUTH_REDIRECT_URI=https://spotify.example.com/callback
#   SPOTIFY_OAUTH_CALLBACK_PORT=53682
