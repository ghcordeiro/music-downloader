{
  "name": "music-downloader",
  "version": "0.1.0",
  "description": "Desktop app to download playlists and tracks as MP3 files with full ID3 tagging.",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "fetch-binaries": "node scripts/fetch-binaries.js",
    "prebuild": "npm run prepare-binaries && npm run embed-creds",
    "dist:mac": "npm run prebuild && electron-builder --mac",
    "dist:win": "npm run prebuild && electron-builder --win",
    "dist": "npm run prebuild && electron-builder --mac --win",
    "prepare-binaries": "node scripts/fetch-binaries.js --all",
    "embed-creds": "node scripts/embed-spotify.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.0",
    "node-id3": "^0.2.6"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "nock": "^13.5.0",
    "vitest": "^1.6.0"
  }
}
